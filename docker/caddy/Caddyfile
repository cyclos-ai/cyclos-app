# Caddy — automatic HTTPS (Let's Encrypt) in front of the app's nginx.
# Caddy obtains + renews the TLS cert for demo.cyclos.ai automatically and
# reverse-proxies to the internal nginx container (which serves the SPA + PHP).
{
	email freighthubcorp@gmail.com
}

# ── Marketing landing (apex domain) ──────────────────────────────────────────
# Served as static files directly by Caddy. The apex must NOT hit the tenant
# app (which requires a subdomain) — so we serve public/portal/index.html here.
# Sign In / Get Started on the page link to the app at demo.cyclos.ai.
# NOTE: www.cyclos.ai is deliberately excluded — its DNS points to GoDaddy/
# Cloudflare, not this VM, so Caddy can't pass the cert challenge for it, and
# grouping it here failed the whole cert order and broke apex TLS. Re-add www
# ONLY after pointing its A record at this VM (136.114.154.133).
cyclos.ai {
	encode gzip zstd
	root * /srv/landing
	file_server
}

# ── Application (multi-tenant) ───────────────────────────────────────────────
# Served on BOTH http and https so deploying Caddy never breaks the site even
# before inbound :443 is opened in the firewall (no forced HTTP->HTTPS redirect).
# Once :443 is open and verified, switch to https-only by removing the http://
# scheme below — Caddy will then auto-redirect HTTP to HTTPS.
http://demo.cyclos.ai, https://demo.cyclos.ai {
	encode gzip zstd
	# Preserves the Host header (tenant subdomain detection) and sets
	# X-Forwarded-Proto so Laravel knows the request scheme.
	reverse_proxy nginx:80
}
