APP_NAME="Cyclos.ai"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8000

# Tenant Configuration
TENANCY_CENTRAL_DOMAINS=cyclos.ai,localhost
TENANT_SUBDOMAIN_SUFFIX=.cyclos.ai

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Central Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cyclos_central
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Session
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@cyclos.ai"
MAIL_FROM_NAME="${APP_NAME}"

# SendGrid
SENDGRID_API_KEY=

# Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=cyclos-ai
AWS_USE_PATH_STYLE_ENDPOINT=false

# Passport OAuth
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# AIS Vessel Tracking API
AIS_API_KEY=
AIS_API_URL=

# Carrier API Integrations
CARRIER_POLLING_INTERVAL=300

# Maersk (MAEU, SUDU, SAFI, CCNI) — https://developer.maersk.com
MAERSK_API_KEY=
MAERSK_CONSUMER_KEY=
MAERSK_API_URL=https://api.maersk.com

# MSC — Mediterranean Shipping Company (MSCU, MEDU)
MSC_API_KEY=
MSC_API_URL=https://www.msc.com/api

# CMA CGM Group (CMDU, ANNU, APLU) — https://developer.cma-cgm.com
CMA_CGM_API_KEY=
CMA_CGM_API_URL=https://api.cma-cgm.com

# COSCO Shipping (COSU, CCLU, OOLU)
COSCO_API_KEY=
COSCO_API_URL=https://elines.coscoshipping.com

# Evergreen Marine (EGLV, EGHU)
EVERGREEN_API_KEY=
EVERGREEN_API_URL=https://www.evergreen-line.com/api

# Hapag-Lloyd (HLCU, HLXU) — OAuth2 client credentials
HAPAG_LLOYD_API_KEY=
HAPAG_LLOYD_CLIENT_ID=
HAPAG_LLOYD_CLIENT_SECRET=
HAPAG_LLOYD_API_URL=https://api.hlag.com

# ONE - Ocean Network Express (ONEY, KKLU, NYKU, MOLU)
ONE_API_KEY=
ONE_API_URL=https://ecomm.one-line.com

# Yang Ming Marine (YMLU, YMJA)
YANG_MING_API_KEY=
YANG_MING_API_URL=https://www.yangming.com/api

# ZIM Integrated Shipping (ZIMU, ZLCU)
ZIM_API_KEY=
ZIM_API_URL=https://www.zim.com/api

# HMM - Hyundai Merchant Marine (HDMU)
HMM_API_KEY=
HMM_API_URL=https://www.hmm21.com/api

# FMCSA SAFER Web Services (Carrier SCAC/USDOT lookup)
# Register at: https://mobile.fmcsa.dot.gov/qc/services/registration
FMCSA_WEB_KEY=

# JSONCargo Container & Vessel Tracking API
# Get an API key at: https://jsoncargo.com/pricing
JSONCARGO_API_KEY=
JSONCARGO_CACHE_TTL=900

# Datalastic AIS vessel tracking (global vessel map)
DATALASTIC_API_KEY=
DATALASTIC_CACHE_TTL=120

# Stripe Billing
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# EDI Webhook
# Shared secret key sent by EDI providers in the X-EDI-Key header.
# Generate with: openssl rand -hex 32
EDI_WEBHOOK_KEY=

# Anthropic Claude API (document OCR / extraction)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Steamship line direct APIs (DCSA Track & Trace fallback)
# Used when JSONCargo has no data. Each carrier uses DCSA T&T 2.x:
#   GET {base_url}/events?equipmentReference={CONTAINER}

# Maersk — OAuth2 client-credentials
# Register at: https://developer.maersk.com
MAERSK_DCSA_URL=
MAERSK_CLIENT_ID=
MAERSK_CLIENT_SECRET=
MAERSK_TOKEN_URL=https://api.maersk.com/oauth2/access_token

# CMA CGM — API key
# Register at: https://developer.cma-cgm.com
CMA_CGM_DCSA_URL=
CMA_CGM_API_KEY=

# Hapag-Lloyd — API key
# Register at: https://developer.hapag-lloyd.com
HAPAG_DCSA_URL=
HAPAG_API_KEY=

# Ocean Network Express (ONE) — API key
ONE_DCSA_URL=
ONE_API_KEY=

# ZIM — API key
ZIM_DCSA_URL=
ZIM_API_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api/v1"
