{
    "name": "cyclos/clm-platform",
    "type": "project",
    "description": "Cyclos.ai Container Lifecycle Management Platform - Multi-tenant SaaS",
    "keywords": ["laravel", "freight", "container", "tracking", "multi-tenant"],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.0",
        "dompdf/dompdf": "^2.0",
        "firebase/php-jwt": "^6.0|^7.0",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.0",
        "laravel/passport": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/telescope": "^5.0",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "predis/predis": "^2.0",
        "sendgrid/sendgrid": "^8.0",
        "spatie/laravel-activitylog": "^4.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-query-builder": "^5.0",
        "stancl/tenancy": "^3.8",
        "stripe/stripe-php": "^20.2",
        "twilio/sdk": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
